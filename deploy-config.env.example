# ─────────────────────────────────────────────────────────────────────────────
#  deploy-config.env — конфигурация деплоя (заполните и переименуйте)
#
#  1. Скопируйте этот файл:
#       cp deploy-config.env.example deploy-config.env
#  2. Заполните все значения ниже
#  3. deploy.sh подхватит их автоматически — ничего вводить не нужно
#
#  ВАЖНО: deploy-config.env содержит пароли — он в .gitignore, не коммитьте!
# ─────────────────────────────────────────────────────────────────────────────

# ── Администратор системы ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_FULL_NAME=Имя Администратора
ADMIN_PASSWORD=ваш_пароль_минимум_8_символов

# ── SMTP (исходящая почта) ────────────────────────────────────────────────────
SMTP_HOST=mail.hosting.reg.ru
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.ru
SMTP_PASSWORD=ваш_smtp_пароль
