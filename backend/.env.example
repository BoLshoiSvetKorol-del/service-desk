# Application
APP_NAME=Service Desk
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# Database
DATABASE_URL=postgresql+asyncpg://servicedesk:servicedesk@postgres:5432/servicedesk

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email — выберите один из способов:

# Вариант 1: SendGrid (https://sendgrid.com)
SENDGRID_API_KEY=
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=Service Desk

# Вариант 2: SMTP (Gmail, Yandex, корпоративный)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=app-password-here
# SMTP_TLS=true
# MAIL_FROM=your@gmail.com
# MAIL_FROM_NAME=Service Desk

# URL портала для ссылок в письмах
PORTAL_URL=http://localhost

# File Storage
# local — папка uploads/ на сервере
# minio — S3-совместимое хранилище
STORAGE_BACKEND=local
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE_MB=10

# CORS — список через запятую или JSON-массив
CORS_ORIGINS=["http://localhost","http://localhost:3000"]

# Admin — создаётся автоматически при первом запуске
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@servicedesk.local
ADMIN_FULL_NAME=Administrator
